
# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Tests / cache
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Runs / artefacts d'expérience
# `runs/*` et NON `runs/` : git ne descend pas dans un RÉPERTOIRE exclu, donc une négation
# `!runs/x/…` plus bas resterait lettre morte. Même forme que `checkpoints/*` ci-dessous.
runs/*
*.jsonl
!specs/**/*.jsonl
# annotations manuelles ERREUR/NOUVEAUTÉ (H3) + trajectoires annotées — versionnées malgré *.jsonl
!data/annotations/**/*.jsonl
!data/annotations/*.jsonl
checkpoints/*
*.pt
*.ckpt

# Logs de session (install / serveur vLLM)
*.log

# --- Artefacts PRÉSERVÉS malgré les règles ci-dessus (survie à la perte du serveur) ---
# Checkpoint JEPA VALIDÉ (gate held-out H1+H2 PASS) : non reproductible sans GPU.
!checkpoints/jepa_tau2_align/
!checkpoints/jepa_tau2_align/**
# Donnée de replay τ² source (régénérable sans LLM via replay_reference_trajectories.py,
# mais versionnée pour restaurer/réentraîner à l'identique). Cf. INSTALL.md §Restauration.
!data/tau2_replay/
!data/tau2_replay/*.jsonl
# Dataset du routeur (jointure traces↔annotations, régénérable via build_router_dataset.py)
# + checkpoint du routeur appris (Phase 4 v0, CV 0.977 vs heuristique 0.817) : versionnés
# pour reproduire la mesure et servir le routeur sans réentraîner.
!data/router/
!data/router/*.jsonl
!checkpoints/router/
!checkpoints/router/**
# Run baseline retail74 (39 ép., 25,6 %) : SOURCE de toutes les mesures du 2026-07-16 — rejeu
# hors-ligne du ranker (2/26, sous le hasard) + décomposition des échecs (12/29 écritures
# prématurées fausses). NON régénérable : le pod est éphémère et le tirage est à temperature
# 0.7, donc un re-run donne d'autres épisodes — c'est précisément ce qu'on veut chiffrer.
# Sans ce fichier, replay_ranker_offline.py et decompose_failures.py n'ont plus d'entrée et
# les chiffres du TODO deviennent invérifiables. ~700 Ko.
!runs/retail74_baseline/
!runs/retail74_baseline/*.jsonl

# Secrets
.env
*.key

# OS / IDE
.DS_Store
.idea/
.vscode/
